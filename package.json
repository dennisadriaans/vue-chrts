{
  "version": "0.0.0",
  "name": "vue-chrts-monorepo",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm --filter \"./packages/**\" build",
    "dev:vue": "pnpm --filter \"vue-chrts\" dev",
    "dev:nuxt": "pnpm --filter \"@vue-chrts/nuxt\" dev",
    "lint": "pnpm --filter \"./packages/**\" lint",
    "typecheck": "pnpm --filter \"./packages/**\" typecheck",
    "release": "node bin/chrts-release.js"
  },
  "bin": {
    "chrts-release": "./bin/chrts-release.js"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "packageManager": "pnpm@8.15.4+sha256.cea6d0bdf2de3a0549582da3983c70c92ffc577ff4410cbf190817ddc35137c2",
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "conventional-commits-parser": "^5.0.0",
    "conventional-changelog-angular": "^7.0.0",
    "execa": "^8.0.1",
    "fast-glob": "^3.3.2",
    "inquirer": "^9.2.15",
    "semver": "^7.6.0",
    "ora": "^8.0.1",
    "update-notifier": "^7.0.0"
  },
  "devDependencies": {
    "@types/inquirer": "^9.0.7",
    "@types/node": "^20.11.25",
    "@types/semver": "^7.5.8",
    "typescript": "^5.3.3"
  }
}